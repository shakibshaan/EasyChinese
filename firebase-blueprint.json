{
  "entities": {
    "Folder": {
      "title": "Flashcard Folder",
      "description": "A container for flashcards.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["name", "userId", "createdAt"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "A single flashcard belonging to a folder.",
      "type": "object",
      "properties": {
        "folderId": { "type": "string" },
        "front": { "type": "string", "description": "Chinese text" },
        "back": { "type": "string", "description": "Meaning/Translation" },
        "pinyin": { "type": "string" },
        "description": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastTested": { "type": "string", "format": "date-time" },
        "difficulty": { "type": "number", "description": "0-5 scale" }
      },
      "required": ["folderId", "front", "back", "userId", "createdAt"]
    },
    "SavedSentence": {
      "title": "Saved Sentence",
      "description": "A sentence analyzed and saved by the user for language learning.",
      "type": "object",
      "properties": {
        "originalText": {
          "type": "string",
          "description": "The original sentence in Chinese or English."
        },
        "translatedText": {
          "type": "string",
          "description": "The full translation of the sentence."
        },
        "breakdown": {
          "type": "array",
          "description": "A word-by-word breakdown of the sentence.",
          "items": {
            "type": "object",
            "properties": {
              "word": { "type": "string" },
              "pinyin": { "type": "string" },
              "translation": { "type": "string" },
              "pos": { "type": "string" },
              "definition": { "type": "string" },
              "context": { "type": "string" }
            }
          }
        },
        "explanation": {
          "type": "string",
          "description": "Grammar or contextual explanation."
        },
        "folderId": {
          "type": "string",
          "description": "The ID of the folder where this sentence is saved."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who saved the sentence."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the sentence was saved."
        },
        "isLearned": {
          "type": "boolean",
          "description": "Whether the user has marked this sentence as learned."
        }
      },
      "required": ["originalText", "translatedText", "breakdown", "userId", "createdAt"]
    },
    "SystemFolder": {
      "title": "System Folder",
      "description": "A pre-defined folder for vocabulary (e.g. HSK).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "parentId": { "type": "string", "description": "Null for top-level" },
        "order": { "type": "number" }
      },
      "required": ["name"]
    },
    "SystemContent": {
      "title": "System Content",
      "description": "Optimized storage for large vocabulary lists.",
      "type": "object",
      "properties": {
        "folderId": { "type": "string" },
        "words": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "word": { "type": "string" },
              "pinyin": { "type": "string" },
              "pos": { "type": "string" },
              "meaning": { "type": "string" },
              "lesson": { "type": "string" }
            }
          }
        }
      },
      "required": ["folderId", "words"]
    },
    "GlobalSentenceCache": {
      "title": "Global Sentence Cache",
      "description": "A global cache of translated sentences to reduce API calls and ensure consistency.",
      "type": "object",
      "properties": {
        "normalized_sentence": { "type": "string" },
        "embedding_vector": { "type": "array", "items": { "type": "number" } },
        "translation_json": { "type": "object" },
        "model_version": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "last_used": { "type": "string", "format": "date-time" },
        "hit_count": { "type": "number" }
      },
      "required": ["normalized_sentence", "translation_json", "model_version"]
    }
  },
  "firestore": {
    "/folders/{folderId}": {
      "schema": "Folder",
      "description": "User folders for organizing flashcards."
    },
    "/flashcards/{flashcardId}": {
      "schema": "Flashcard",
      "description": "Individual flashcards."
    },
    "/sentences/{sentenceId}": {
      "schema": "SavedSentence",
      "description": "Collection of saved sentences for language learning."
    },
    "/system_folders/{folderId}": {
      "schema": "SystemFolder",
      "description": "Pre-included vocabulary categories."
    },
    "/system_content/{contentId}": {
      "schema": "SystemContent",
      "description": "Bulk vocabulary data for system folders."
    },
    "/global_sentence_cache/{docId}": {
      "schema": "GlobalSentenceCache",
      "description": "Global semantic cache for sentence translations."
    }
  }
}
